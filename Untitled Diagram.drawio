        <mxCell id="AA5P-qOjUl-CRV39_Xl2-6" parent="1" style="whiteSpace=wrap;html=1;fontSize=21;fillColor=#e51400;strokeColor=#B20000;rounded=1;fontColor=#ffffff;" value="we should have unit amount of UI which can&#39;t be splitted into multiple other components." vertex="1">
          <mxGeometry height="220" width="513.75" x="698.13" y="380" as="geometry" />
        </mxCell>
        <mxCell id="AA5P-qOjUl-CRV39_Xl2-11" edge="1" parent="1" source="AA5P-qOjUl-CRV39_Xl2-8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="AA5P-qOjUl-CRV39_Xl2-10" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="AA5P-qOjUl-CRV39_Xl2-8" parent="1" style="whiteSpace=wrap;html=1;fontSize=21;fillColor=#0050ef;strokeColor=#001DBC;fontColor=#ffffff;rounded=1;" value="2 types of components are there .&lt;div&gt;1. Smart : who can help us to make any decision since they are holding the BL for UI and they are capable to perform the rest calls.&lt;/div&gt;&lt;div&gt;2. Dumb: are used to accept or render the data &lt;b&gt;NO BL NO REST CALLS.&lt;/b&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="670" x="620" y="700" as="geometry" />
        </mxCell>
        <mxCell id="AA5P-qOjUl-CRV39_Xl2-13" edge="1" parent="1" source="AA5P-qOjUl-CRV39_Xl2-10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="AA5P-qOjUl-CRV39_Xl2-12" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
